{
	"name": "dacia-over-reacts",
	"version": "0.1.0",
	"private": true,
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"dependencies": {
		"@davidanddacia/react-ui-components": "github:davidanddacia/react-ui-components",
		"@emotion/react": "11.14.0",
		"@emotion/styled": "11.14.0",
		"@reduxjs/toolkit": "1.9.7",
		"react": "18.2.0",
		"react-dom": "18.2.0",
		"react-redux": "8.1.2",
		"react-router-dom": "7.0.2",
		"sass": "1.74.1",
		"vite": "5.4.2"
	},
	"devDependencies": {
		"@cspell/eslint-plugin": "9.6.2",
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "9.39.4",
		"@playwright/test": "1.50.1",
		"@stylistic/eslint-plugin": "5.7.1",
		"@testing-library/jest-dom": "6.3.0",
		"@testing-library/react": "14.0.0",
		"@testing-library/user-event": "14.5.2",
		"@types/jest": "29.5.14",
		"@types/node": "22.13.8",
		"@types/react": "18.2.66",
		"@types/react-dom": "18.2.23",
		"@typescript-eslint/eslint-plugin": "8.54.0",
		"@typescript-eslint/parser": "8.54.0",
		"@vitejs/plugin-react": "4.3.1",
		"cssnano": "6.1.2",
		"eslint": "9.39.4",
		"eslint-plugin-perfectionist": "5.9.0",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-simple-import-sort": "12.1.1",
		"eslint-plugin-unicorn": "64.0.0",
		"husky": "9.1.7",
		"jsdom": "28.1.0",
		"postcss": "8.5.1",
		"postcss-import": "16.1.0",
		"postcss-preset-env": "9.6.0",
		"postcss-scss": "4.0.9",
		"typescript": "5.8.2",
		"vitest": "1.1.3"
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite",
		"e2e:debug": "playwright test --debug",
		"e2e:headed": "playwright test --headed",
		"e2e:report": "playwright show-report",
		"e2e": "playwright test",
		"format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
		"lint": "eslint --fix \"src/**/*.{js,ts,tsx}\" \"tests/**/*.{js,ts,tsx}\" \"vite.config.ts\"",
		"prepare": "chmod +x .husky/*",
		"preview": "vite preview",
		"test:coverage": "vitest --coverage",
		"test:ui": "vitest --ui",
		"test:watch": "vitest --watch",
		"test": "vitest"
	}
}
